# Mailchimp Configuration
# Get these values from your Mailchimp account settings.
# API Key: Account > Extras > API Keys
# List ID: Audience > Settings > Audience name and defaults (scroll to "Audience ID")
# Server Prefix: The first part of your API key after the dash (e.g., "us1", "us2", etc.)
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_LIST_ID=your_mailchimp_list_id_here
MAILCHIMP_SERVER_PREFIX=us1

# Zapier Webhook URL (optional)
# If you have a Zapier workflow set up to send data to Google Sheets,
# paste the webhook URL here. If not set, backup submissions will be skipped.
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ZAPIER_ID/YOUR_WEBHOOK_ID

# Analytics Configuration (optional)
# If using Plausible Analytics, set your domain here.
# If using Google Analytics 4, ensure the gtag script is in your HTML.
PLAUSIBLE_DOMAIN=yourdomain.com
